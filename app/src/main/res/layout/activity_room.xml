<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/heartbeat_animated_bg">

    <!-- Background Animation Container -->
    <FrameLayout
        android:id="@+id/love_animation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:clickable="false"
        android:focusable="false" />

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/melodify_logo_header"
            android:layout_width="80dp"
            android:layout_height="24dp"
            android:src="@drawable/logo"
            android:scaleType="fitStart"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Melodify Logo" />

        <TextView
            android:id="@+id/room_name_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Room Name"
            android:textColor="@color/melodify_pink"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/host_info_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/melodify_logo_header">

            <TextView
                android:id="@+id/host_name_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DJ: Alex.vibe"
                android:textColor="@color/melodify_text_secondary"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/room_code_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/glass_card_bg"
                android:backgroundTint="#22FFFFFF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="2dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/room_code_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Code: Loading..."
                    android:textColor="@color/melodify_pink"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 📋"
                    android:textColor="@color/melodify_pink"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/top_actions_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/top_music_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                android:src="@drawable/ic_music_note"
                app:tint="@color/white"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <ImageButton
                android:id="@+id/btn_room_more"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/white"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:contentDescription="More options" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/right_stats_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_actions_container">

            <TextView
                android:id="@+id/member_count_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.2k Live"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:background="@drawable/glass_card_bg"
                android:backgroundTint="#22FFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_open_queue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUEUE"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/glass_card_bg"
                android:backgroundTint="#22FFFFFF"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/host_warning_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E02424"
        android:gravity="center"
        android:padding="4dp"
        android:text="Waiting for a new host..."
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/header_bar" />

    <TextView
        android:id="@+id/queue_empty_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/melodify_pink"
        android:gravity="center"
        android:padding="4dp"
        android:text="Queue is empty - add songs!"
        android:textColor="@color/melodify_background"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/host_warning_banner" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/queue_empty_banner"
        app:layout_constraintBottom_toTopOf="@id/bottom_input_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- 5 Audience Seats + 1 Host Seat -->
            <LinearLayout
                android:id="@+id/seats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="12dp">
                <!-- Host Seat -->
                <LinearLayout
                    android:id="@+id/seat1_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout android:layout_width="50dp" android:layout_height="50dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/host_avatar"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            app:strokeColor="@color/melodify_pink" app:strokeWidth="2dp"
                            app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                            android:src="@drawable/ic_user_placeholder" />
                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:background="@color/melodify_pink" android:text="HOST"
                            android:textColor="@color/melodify_background" android:textSize="7sp"
                            android:textStyle="bold" android:paddingHorizontal="4dp" android:layout_marginBottom="-4dp" />
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/host_reaction_lottie"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:visibility="invisible" />
                    </FrameLayout>
                </LinearLayout>
                <!-- Seat 2 -->
                <LinearLayout
                    android:id="@+id/seat2_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="4dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/seat2_avatar"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                            android:src="@drawable/ic_user_placeholder" />
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/seat2_reaction_lottie"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:visibility="invisible" />
                    </FrameLayout>
                    <TextView android:id="@+id/seat2_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="@color/melodify_text_secondary" android:textSize="8sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <!-- Seat 3 -->
                <LinearLayout
                    android:id="@+id/seat3_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="4dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/seat3_avatar"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                            android:src="@drawable/ic_user_placeholder" />
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/seat3_reaction_lottie"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:visibility="invisible" />
                    </FrameLayout>
                    <TextView android:id="@+id/seat3_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="@color/melodify_text_secondary" android:textSize="8sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <!-- Seat 4 -->
                <LinearLayout
                    android:id="@+id/seat4_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="4dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/seat4_avatar"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                            android:src="@drawable/ic_user_placeholder" />
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/seat4_reaction_lottie"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:visibility="invisible" />
                    </FrameLayout>
                    <TextView android:id="@+id/seat4_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="@color/melodify_text_secondary" android:textSize="8sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <!-- Seat 5 -->
                <LinearLayout
                    android:id="@+id/seat5_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="4dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/seat5_avatar"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                            android:src="@drawable/ic_user_placeholder" />
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/seat5_reaction_lottie"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:visibility="invisible" />
                    </FrameLayout>
                    <TextView android:id="@+id/seat5_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="@color/melodify_text_secondary" android:textSize="8sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <!-- Seat 6 -->
                <LinearLayout
                    android:id="@+id/seat6_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="4dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="44dp" android:layout_height="44dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/seat6_avatar"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                            android:src="@drawable/ic_user_placeholder" />
                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/seat6_reaction_lottie"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:visibility="invisible" />
                    </FrameLayout>
                    <TextView android:id="@+id/seat6_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="@color/melodify_text_secondary" android:textSize="8sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Player Card -->
            <LinearLayout
                android:id="@+id/player_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/glass_card_bg"
                android:orientation="vertical"
                android:padding="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:id="@+id/track_art_container"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentStart="true">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/track_art"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/black"
                            android:padding="4dp"
                            app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                            android:src="@drawable/ic_music_note"
                            app:tint="@color/white" />

                        <LinearLayout
                            android:id="@+id/equalizer_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:layout_margin="6dp"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:visibility="gone">
                            <View android:id="@+id/eq_bar1" android:layout_width="2dp" android:layout_height="12dp" android:background="@color/melodify_pink" android:layout_marginEnd="1dp"/>
                            <View android:id="@+id/eq_bar2" android:layout_width="2dp" android:layout_height="12dp" android:background="@color/melodify_pink" android:layout_marginEnd="1dp"/>
                            <View android:id="@+id/eq_bar3" android:layout_width="2dp" android:layout_height="12dp" android:background="@color/melodify_pink" />
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/track_info_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/track_art_container"
                        android:layout_toStartOf="@id/card_actions_container"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/track_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Song Playing"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                        <TextView
                            android:id="@+id/track_artist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose a song to start"
                            android:textColor="@color/melodify_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/sync_status_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Synced"
                            android:textColor="#1DB954"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_actions_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btn_minimize_player"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_minimize"
                            app:tint="@color/melodify_text_secondary"
                            android:padding="6dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="Minimize player" />

                        <LinearLayout
                            android:id="@+id/host_controls_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageButton
                                android:id="@+id/play_pause_btn"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/play_btn_bg"
                                android:src="@android:drawable/ic_media_play"
                                android:padding="6dp"
                                android:scaleType="fitCenter"
                                app:tint="@color/melodify_background" />
                            <ImageButton
                                android:id="@+id/skip_btn"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/play_btn_bg"
                                android:src="@android:drawable/ic_media_next"
                                android:padding="6dp"
                                android:scaleType="fitCenter"
                                app:tint="@color/melodify_background" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/expanded_player_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <SeekBar
                        android:id="@+id/track_seekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:progressTint="@color/melodify_pink"
                        android:thumb="@drawable/seekbar_thumb"
                        android:splitTrack="false" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp"
                        android:layout_marginTop="2dp">
                        <TextView
                            android:id="@+id/track_time_elapsed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="@color/melodify_text_secondary"
                            android:textSize="9sp" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                        <TextView
                            android:id="@+id/track_time_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="@color/melodify_text_secondary"
                            android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Queue Preview -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/queue_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <!-- Chat Discussion -->
            <LinearLayout
                android:id="@+id/chat_container"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:background="@drawable/glass_card_bg"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE DISCUSSION" android:textColor="@color/white"
                    android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.1" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/chat_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginTop="8dp" />
                <TextView
                    android:id="@+id/typing_indicator_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User is typing..." android:textColor="@color/melodify_pink"
                    android:textSize="10sp" android:textStyle="italic" android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Input -->
    <LinearLayout
        android:id="@+id/bottom_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/reply_draft_bar"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/glass_card_bg"
            android:backgroundTint="#33FFFFFF" android:padding="8dp"
            android:layout_marginBottom="8dp" android:gravity="center_vertical" android:visibility="gone">
            <View android:layout_width="3dp" android:layout_height="match_parent" android:background="@color/melodify_pink" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_weight="1" android:layout_marginStart="12dp">
                <TextView android:id="@+id/reply_draft_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/melodify_pink" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/reply_draft_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#B3FFFFFF" android:textSize="11sp" android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>
            <ImageButton android:id="@+id/cancel_reply_btn" android:layout_width="28dp" android:layout_height="28dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="@color/melodify_text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/emoji_fire_btn"
                android:layout_width="36dp" android:layout_height="36dp"
                android:background="@drawable/edit_text_bg" android:text="🔥"
                android:textSize="16sp" android:gravity="center" android:clickable="true" android:focusable="true"/>
            <TextView
                android:id="@+id/emoji_heart_btn"
                android:layout_width="36dp" android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/edit_text_bg" android:text="❤️"
                android:textSize="16sp" android:gravity="center" android:clickable="true" android:focusable="true"/>
            <TextView
                android:id="@+id/emoji_wow_btn"
                android:layout_width="36dp" android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/edit_text_bg" android:text="😮"
                android:textSize="16sp" android:gravity="center" android:clickable="true" android:focusable="true"/>
            <TextView
                android:id="@+id/emoji_angry_btn"
                android:layout_width="36dp" android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/edit_text_bg" android:text="😠"
                android:textSize="16sp" android:gravity="center" android:clickable="true" android:focusable="true"/>
            <TextView
                android:id="@+id/emoji_favorite_btn"
                android:layout_width="36dp" android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/edit_text_bg" android:text="⭐"
                android:textSize="16sp" android:gravity="center" android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/add_to_queue_helper_btn"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/glass_card_bg" android:src="@android:drawable/ic_input_add" app:tint="@color/white" />
            <EditText
                android:id="@+id/chat_input"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:layout_marginHorizontal="10dp"
                android:background="@drawable/edit_text_bg" android:hint="Share your thoughts..."
                android:textColorHint="@color/melodify_text_secondary" android:textColor="@color/white"
                android:paddingHorizontal="16dp" android:textSize="14sp" />
            <ImageButton
                android:id="@+id/chat_send_btn"
                android:layout_width="48dp" android:layout_height="48dp"
                android:background="@drawable/send_btn_bg" android:src="@android:drawable/ic_menu_send"
                android:padding="10dp" android:scaleType="fitCenter" app:tint="@color/melodify_background" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/btn_mic_toggle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🎙 Muted" android:textColor="@color/melodify_text_secondary"
                android:textSize="12sp" android:padding="4dp" />
            <TextView
                android:id="@+id/btn_wave"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌊 Wave" android:textColor="@color/melodify_text_secondary"
                android:textSize="12sp" android:layout_marginStart="16dp" android:padding="4dp"
                android:clickable="true" android:focusable="true" />
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
            <TextView
                android:id="@+id/btn_dj_info"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dj" android:textColor="@color/melodify_pink"
                android:textSize="11sp" android:textStyle="bold" android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" android:background="@drawable/glass_card_bg"
                android:backgroundTint="#11FFFFFF" android:clickable="true" android:focusable="true" />
            <TextView
                android:id="@+id/btn_codj_info"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Co-Dj" android:textColor="@color/melodify_pink"
                android:textSize="11sp" android:textStyle="bold" android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" android:layout_marginStart="8dp"
                android:background="@drawable/glass_card_bg"
                android:backgroundTint="#11FFFFFF" android:clickable="true" android:focusable="true" />
            <Button android:id="@+id/request_aux_btn" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/emoji_overlay_container"
        android:layout_width="match_parent" android:layout_height="match_parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
