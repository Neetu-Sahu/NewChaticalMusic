<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chat_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/heartbeat_animated_bg">

    <!-- Background Animation Container -->
    <FrameLayout
        android:id="@+id/love_animation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:clickable="false"
        android:focusable="false" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/chat_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1AFFFFFF"
        android:elevation="4dp"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/chat_header_info"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="8dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/chat_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
                android:src="@drawable/ic_user_placeholder"
                android:scaleType="centerCrop"
                app:strokeColor="@color/melodify_pink"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/chat_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Maya J." />
                <TextView
                    android:id="@+id/chat_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/melodify_text_secondary"
                    android:textSize="11sp"
                    tools:text="Online" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/search_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/melodify_background"
        android:orientation="vertical"
        android:visibility="gone"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btn_close_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white" />

            <EditText
                android:id="@+id/search_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search messages..."
                android:textColorHint="@color/melodify_text_secondary"
                android:textColor="@color/white"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:padding="8dp" />

            <TextView
                android:id="@+id/search_count_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/melodify_pink"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:text="0/0"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_prev_search"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/arrow_up_float"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btn_next_search"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/white" />
        </LinearLayout>

        <TextView
            android:id="@+id/search_no_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No messages found"
            android:textColor="@color/melodify_pink"
            android:gravity="center"
            android:padding="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/direct_chat_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/chat_toolbar"
        app:layout_constraintBottom_toTopOf="@id/typing_indicator_container" />

    <FrameLayout
        android:id="@+id/typing_indicator_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_input_container">
        <include layout="@layout/item_typing_indicator" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottom_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Reply Draft Bar -->
        <LinearLayout
            android:id="@+id/reply_draft_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/glass_card_bg"
            android:backgroundTint="#33FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <View android:layout_width="3dp" android:layout_height="match_parent" android:background="@color/melodify_pink" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_weight="1" android:layout_marginStart="12dp">
                <TextView android:id="@+id/reply_draft_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/melodify_pink" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/reply_draft_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#B3FFFFFF" android:textSize="11sp" android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>
            <ImageButton android:id="@+id/cancel_reply_btn" android:layout_width="28dp" android:layout_height="28dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="@color/melodify_text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/chat_input"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:hint="Message..."
                android:textColorHint="@color/melodify_text_secondary"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/chat_send_btn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/send_btn_bg"
                android:src="@android:drawable/ic_menu_send"
                android:padding="10dp"
                android:scaleType="fitCenter"
                app:tint="@color/melodify_background" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>