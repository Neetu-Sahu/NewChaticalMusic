<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="2dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#1AFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Room Icon or Music Symbol -->
        <ImageView
            android:id="@+id/room_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/glass_card_bg"
            android:backgroundTint="#33FFFFFF"
            android:padding="8dp"
            android:src="@drawable/ic_music_placeholder"
            android:layout_marginRight="12dp"
            app:tint="#1DB954" />

        <!-- Info Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/public_room_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="Rock Jam Room" />

            <TextView
                android:id="@+id/public_room_song"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="Now Playing: None" />
        </LinearLayout>

        <!-- Presence/Members Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/glass_card_bg"
            android:backgroundTint="#2C2C2E"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/public_room_members"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1DB954"
                android:textSize="12sp"
                android:textStyle="bold"
                android:text="👤 1" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
