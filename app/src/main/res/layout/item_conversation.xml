<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/conv_avatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
        android:src="@drawable/ic_user_placeholder"
        android:background="#2C2C2E" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/conv_avatar"
        android:layout_toStartOf="@id/conv_unread_count"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        android:layout_centerVertical="true">

        <TextView
            android:id="@+id/conv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/conv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/melodify_pink"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="Online"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/conv_last_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Hello, how are you?" />

    </LinearLayout>

    <TextView
        android:id="@+id/conv_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:textColor="#888888"
        android:textSize="12sp"
        tools:text="10:42 AM" />

    <ImageView
        android:id="@+id/conv_mute_indicator"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_toStartOf="@id/conv_timestamp"
        android:layout_marginEnd="4dp"
        android:layout_alignTop="@id/conv_timestamp"
        android:src="@drawable/ic_mute"
        app:tint="#888888"
        android:visibility="gone" />

    <TextView
        android:id="@+id/conv_unread_count"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/conv_timestamp"
        android:layout_marginTop="8dp"
        android:background="@drawable/unread_badge_bg"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        tools:text="3" />

</RelativeLayout>
