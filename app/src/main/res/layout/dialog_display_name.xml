<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_card_bg"
    android:backgroundTint="@color/melodify_background"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/drag_handle_bg"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What should we call you?"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose a display name for chat rooms and sharing."
        android:textColor="@color/melodify_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/display_name_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter display name"
        android:textColor="@color/white"
        android:textColorHint="@color/melodify_text_secondary"
        android:textSize="16sp"
        android:background="@drawable/edit_text_bg"
        android:padding="16dp"
        android:inputType="textPersonName"
        android:maxLines="1"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_confirm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirm"
        android:textColor="@color/melodify_background"
        android:textStyle="bold"
        android:backgroundTint="@color/melodify_pink"
        app:cornerRadius="28dp" />

</LinearLayout>
