<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/search_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/heartbeat_animated_bg"
    tools:context=".SearchActivity">

    <!-- Background Animation Container -->
    <FrameLayout
        android:id="@+id/love_animation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:clickable="false"
        android:focusable="false" />

    <!-- Search Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/search_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Search Music"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Search Bar Layout -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/search_bar_layout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:hint="Search for music..."
        app:boxStrokeColor="@color/melodify_pink"
        app:boxStrokeWidth="1.5dp"
        app:boxStrokeWidthFocused="2dp"
        app:hintTextColor="@color/melodify_pink"
        app:boxCornerRadiusTopStart="24dp"
        app:boxCornerRadiusTopEnd="24dp"
        app:boxCornerRadiusBottomStart="24dp"
        app:boxCornerRadiusBottomEnd="24dp"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/white"
        app:endIconMode="clear_text"
        app:endIconTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/search_toolbar">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/search_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/melodify_text_secondary"
            android:textColor="@color/white"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:imeOptions="actionSearch"
            android:textSize="15sp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Pre-Search Content -->
    <LinearLayout
        android:id="@+id/pre_search_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/search_bar_layout"
        app:layout_constraintBottom_toTopOf="@id/mini_player_bar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse by mood"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="24dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/mood_chip_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_lofi"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lo-fi"
                    android:textColor="@color/white"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_chill"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chill"
                    android:textColor="@color/white"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_hype"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hype"
                    android:textColor="@color/white"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_focus"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focus"
                    android:textColor="@color/white"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sleep"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sleep"
                    android:textColor="@color/white"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_happy"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Happy"
                    android:textColor="@color/white"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeWidth="0dp"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/recent_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recently played"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recent_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"/>

        <TextView
            android:id="@+id/recent_empty_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nothing played yet — search above"
            android:textColor="@color/melodify_text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Results RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_results_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/search_bar_layout"
        app:layout_constraintBottom_toTopOf="@id/mini_player_bar"
        tools:listitem="@layout/item_track"/>

    <!-- Empty state results text -->
    <TextView
        android:id="@+id/search_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="No results found"
        android:textColor="@color/melodify_text_secondary"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/search_bar_layout"
        app:layout_constraintBottom_toTopOf="@id/mini_player_bar"/>

    <!-- Connection error state layout -->
    <LinearLayout
        android:id="@+id/search_error_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/search_bar_layout"
        app:layout_constraintBottom_toTopOf="@id/mini_player_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/error_message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Connection error — tap to retry"
            android:textColor="@color/melodify_pink"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/retry_search_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/melodify_pink"
            android:text="Retry"
            android:textColor="@color/melodify_background"
            app:cornerRadius="20dp"/>
    </LinearLayout>

    <!-- Persistent Mini Player Bar -->
    <LinearLayout
        android:id="@+id/mini_player_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/melodify_card"
        android:elevation="8dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/mini_art"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="@color/melodify_background"
            app:shapeAppearanceOverlay="@style/RoundedCorner4dp"
            tools:srcCompat="@drawable/ic_music_placeholder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="10dp">

            <TextView
                android:id="@+id/mini_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Track Title" />

            <TextView
                android:id="@+id/mini_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/melodify_text_secondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Artist Name" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/mini_play_pause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play_arrow"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Play or pause"
            app:tint="@color/melodify_pink"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/mini_skip"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_skip_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Skip to next"
            app:tint="@color/white" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/search_progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/melodify_pink"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>