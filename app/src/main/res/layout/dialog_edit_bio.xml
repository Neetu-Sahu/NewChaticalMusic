<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/glass_card_bg"
    android:backgroundTint="@color/melodify_background">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/drag_handle_bg"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Update your melody bio"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/bio_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:gravity="top"
        android:background="@drawable/edit_text_bg"
        android:padding="16dp"
        android:hint="Type something about your vibe..."
        android:textColor="@color/white"
        android:textColorHint="@color/melodify_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_save_bio"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save Bio"
        android:backgroundTint="@color/melodify_pink"
        android:textColor="@color/melodify_background"
        android:textStyle="bold"
        app:cornerRadius="28dp" />

</LinearLayout>
