<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="2dp">

    <!-- Indentation spacer (Width matches avatar + margin) -->
    <View
        android:layout_width="40dp"
        android:layout_height="0dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Reply Preview Bar for Compact -->
        <LinearLayout
            android:id="@+id/reply_preview_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/glass_card_bg"
            android:backgroundTint="#22FFFFFF"
            android:padding="4dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone">

            <View
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:background="#1DB954" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/reply_preview_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textColor="#1DB954"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reply_preview_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/chat_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Indented compact message text."
            android:textColor="#EFEFEF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chat_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:layout_marginTop="1dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
