<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/requester_image"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircleAppearance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:src="@drawable/ic_user_placeholder" />

    <TextView
        android:id="@+id/requester_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Display Name"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/requester_username"
        app:layout_constraintEnd_toStartOf="@id/actions_layout"
        app:layout_constraintStart_toEndOf="@id/requester_image"
        app:layout_constraintTop_toTopOf="@id/requester_image"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/requester_username"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="username"
        android:textColor="@color/melodify_text_secondary"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/requester_image"
        app:layout_constraintEnd_toStartOf="@id/actions_layout"
        app:layout_constraintStart_toEndOf="@id/requester_image"
        app:layout_constraintTop_toBottomOf="@id/requester_name" />

    <LinearLayout
        android:id="@+id/actions_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btn_accept"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accept"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_decline"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Decline"
            android:textSize="12sp"
            app:backgroundTint="@color/melodify_card"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btn_follow_back"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Follow Back"
            android:textSize="12sp"
            android:visibility="gone"
            app:backgroundTint="@color/melodify_pink"
            android:textColor="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>