<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/full_player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:padding="0dp">

    <!-- A) Drag handle -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/drag_handle_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- B) Album art -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/fullArt"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_placeholder"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:shapeAppearanceOverlay="@style/RoundedCorner16dp" />

    <View
        android:id="@+id/gradient_accent"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/gradient_player_bg"
        app:layout_constraintTop_toBottomOf="@id/fullArt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- C) Track title -->
    <TextView
        android:id="@+id/fullTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Track Title"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullArt" />

    <!-- D) Artist name -->
    <TextView
        android:id="@+id/fullArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="32dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Artist Name"
        android:textColor="#888888"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullTitle" />

    <!-- E) SeekBar -->
    <SeekBar
        android:id="@+id/fullSeekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="32dp"
        android:backgroundTint="#333333"
        android:progressTint="#22C55E"
        android:thumbTint="#22C55E"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullArtist" />

    <!-- F) Time row -->
    <TextView
        android:id="@+id/fullCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="4dp"
        android:text="00:00"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullSeekBar" />

    <TextView
        android:id="@+id/fullDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="32dp"
        android:text="00:00"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullSeekBar" />

    <!-- G) Controls row -->
    <ImageButton
        android:id="@+id/fullPlayPause"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Play or Pause"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_play_arrow"
        app:tint="#22C55E"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullCurrentTime" />

    <ImageButton
        android:id="@+id/fullSkipPrev"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Skip Previous"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_skip_previous"
        app:tint="#CCCCCC"
        app:layout_constraintBottom_toTopOf="@id/fullPlayPause"
        app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
        app:layout_constraintEnd_toStartOf="@id/fullPlayPause"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/fullPlayPause" />

    <ImageButton
        android:id="@+id/fullSkipNext"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Skip Next"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_skip_next"
        app:tint="#CCCCCC"
        app:layout_constraintBottom_toTopOf="@id/fullPlayPause"
        app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
        app:layout_constraintStart_toEndOf="@id/fullPlayPause"
        android:layout_marginStart="40dp"
        app:layout_constraintTop_toBottomOf="@id/fullPlayPause" />

</androidx.constraintlayout.widget.ConstraintLayout>
