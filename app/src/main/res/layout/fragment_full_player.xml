<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/full_player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/heartbeat_animated_bg"
    android:padding="0dp">

    <!-- Background Animation Container -->
    <FrameLayout
        android:id="@+id/love_animation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:clickable="false"
        android:focusable="false" />

    <!-- A) Drag handle -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/drag_handle_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- B) Album art -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/fullArt"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_placeholder"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:shapeAppearanceOverlay="@style/RoundedCorner16dp"
        app:strokeColor="@color/melodify_pink"
        app:strokeWidth="1dp" />

    <!-- C) Track title -->
    <TextView
        android:id="@+id/fullTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Track Title"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullArt" />

    <!-- D) Artist name -->
    <TextView
        android:id="@+id/fullArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="32dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Artist Name"
        android:textColor="@color/melodify_text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullTitle" />

    <!-- E) SeekBar -->
    <SeekBar
        android:id="@+id/fullSeekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp"
        android:progressTint="@color/melodify_pink"
        android:thumb="@drawable/seekbar_thumb"
        android:splitTrack="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullArtist" />

    <!-- F) Time row -->
    <TextView
        android:id="@+id/fullCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="8dp"
        android:text="00:00"
        android:textColor="@color/melodify_text_secondary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullSeekBar" />

    <TextView
        android:id="@+id/fullDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="32dp"
        android:text="00:00"
        android:textColor="@color/melodify_text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullSeekBar" />

    <!-- G) Controls row -->
    <ImageButton
        android:id="@+id/fullPlayPause"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/play_btn_bg"
        android:contentDescription="Play or Pause"
        android:padding="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_play_arrow"
        app:tint="@color/melodify_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fullCurrentTime" />

    <ImageButton
        android:id="@+id/fullSkipPrev"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Skip Previous"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
        app:layout_constraintEnd_toStartOf="@id/fullPlayPause"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toTopOf="@id/fullPlayPause" />

    <ImageButton
        android:id="@+id/fullSkipNext"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Skip Next"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_media_next"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/fullPlayPause"
        app:layout_constraintStart_toEndOf="@id/fullPlayPause"
        android:layout_marginStart="40dp"
        app:layout_constraintTop_toTopOf="@id/fullPlayPause" />

</androidx.constraintlayout.widget.ConstraintLayout>
