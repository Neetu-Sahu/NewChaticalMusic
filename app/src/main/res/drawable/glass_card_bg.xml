<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Semi-transparent deep maroon/pinkish overlay for glass effect -->
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#2AFFFFFF"
        android:centerColor="#1AFFFFFF"
        android:endColor="#0DFFFFFF" />

    <!-- Thin light pink/white border for glass reflection -->
    <stroke
        android:width="1dp"
        android:color="#33FF829B"/>

    <corners android:radius="24dp"/>
</shape>
